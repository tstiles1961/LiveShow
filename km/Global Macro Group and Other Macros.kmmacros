						<string>#!/bin/zsh -f
/usr/bin/osascript &lt;&lt;'OSA'
tell application "GarageBand" to activate
delay 0.4
tell application "Skim" to activate
delay 0.6

tell application "System Events"
    tell process "Skim"
        try
            set value of attribute "AXFullScreen" of window 1 to false
        end try
    end tell
end tell
delay 0.6

tell application "Skim" to activate
delay 0.4
tell application "System Events"
    tell process "Skim"
        try
            set value of attribute "AXFullScreen" of window 1 to true
        on error
            try
                keystroke "f" using {control down, command down}
            end try
        end try
    end tell
end tell
OSA

echo "Dual-display layout applied: GarageBand stays on the primary display, and Skim is set to native full-screen on the second display."
</string>
