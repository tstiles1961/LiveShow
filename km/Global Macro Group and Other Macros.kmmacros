						<string>use AppleScript version "2.4"
use scripting additions

on setKMVar(varName, varValue)
	tell application "Keyboard Maestro Engine"
		setvariable varName to (varValue as text)
	end tell
end setKMVar

on getKMVar(varName)
	tell application "Keyboard Maestro Engine"
		return getvariable varName
	end tell
end getKMVar

set setListID to my getKMVar("LiveShow_SetListID")
set songMasterID to my getKMVar("LiveShow_SongMasterID")

if setListID is "" or songMasterID is "" then
	my setKMVar("LiveShow_ResolveStatus", "ERROR")
	my setKMVar("LiveShow_ResolveMessage", "Missing set_list_id or song_master_id")
	display dialog "LiveShow_Resolve_And_Load: missing set_list_id or song_master_id" buttons {"OK"} default button 1
	return
end if

set dataFolder to "/Users/timstiles/Music/LiveShow/Data/"
set setSongCSV to dataFolder &amp; "set_song.csv"
set songMasterCSV to dataFolder &amp; "song_master.csv"
set setListCSV to dataFolder &amp; "set_list.csv"

set py to "
import csv, sys

set_song_csv, song_master_csv, set_list_csv, set_list_id, song_master_id = sys.argv[1:6]

def norm(v):
    return str(v).strip()

set_song = {}
with open(set_song_csv, newline='', encoding='utf-8-sig') as f:
    for row in csv.DictReader(f):
        if norm(row.get('set_list_id','')) == set_list_id and norm(row.get('song_master_id','')) == song_master_id:
            set_song = row
            break

song_master = {}
with open(song_master_csv, newline='', encoding='utf-8-sig') as f:
    for row in csv.DictReader(f):
        if norm(row.get('song_master_id','')) == song_master_id:
            song_master = row
            break

set_list = {}
with open(set_list_csv, newline='', encoding='utf-8-sig') as f:
    for row in csv.DictReader(f):
        if norm(row.get('set_list_id','')) == set_list_id:
            set_list = row
            break

def g(src, key):
    return norm(src.get(key,'')) if src else ''

result = {
 'set_song_id': g(set_song,'set_song_id'),
 'start_time': g(set_song,'start_time'),
 'order_in_set': g(set_song,'order_in_set'),
 'override_lyrics_path': g(set_song,'override_lyrics_path'),
 'override_scroll_y': g(set_song,'override_scroll_y'),
 'override_cam_profile_id': g(set_song,'override_cam_profile_id'),
 'song_name': g(song_master,'song_name'),
 'artist': g(song_master,'artist'),
 'default_lyrics_path': g(song_master,'default_lyrics_path'),
 'default_scroll_y': g(song_master,'default_scroll_y'),
 'cam_profile_id': g(song_master,'cam_profile_id'),
 'set_name': g(set_list,'set_name'),
 'set_file_name': g(set_list,'set_file_name')
}
result['effective_lyrics_path'] = result['override_lyrics_path'] or result['default_lyrics_path']
result['effective_scroll_y'] = result['override_scroll_y'] or result['default_scroll_y']
result['effective_cam_profile_id'] = result['override_cam_profile_id'] or result['cam_profile_id']

for k, v in result.items():
    print(f'{k}={v}')
"
try
	set parsedLines to do shell script "/usr/bin/python3 -c " &amp; quoted form of py &amp; space &amp; quoted form of setSongCSV &amp; space &amp; quoted form of songMasterCSV &amp; space &amp; quoted form of setListCSV &amp; space &amp; quoted form of setListID &amp; space &amp; quoted form of songMasterID
on error errMsg
	my setKMVar("LiveShow_ResolveStatus", "ERROR")
	my setKMVar("LiveShow_ResolveMessage", "CSV lookup failed: " &amp; errMsg)
	display dialog "CSV lookup failed: " &amp; errMsg buttons {"OK"} default button 1
	return
end try

repeat with oneLine in paragraphs of parsedLines
	if oneLine contains "=" then
		set AppleScript's text item delimiters to "="
		set k to text item 1 of oneLine
		set v to (items 2 thru -1 of text items of oneLine) as text
		set AppleScript's text item delimiters to ""
		if k is "set_song_id" then my setKMVar("LiveShow_SetSongID", v)
		if k is "start_time" then my setKMVar("LiveShow_StartTime", v)
		if k is "order_in_set" then my setKMVar("LiveShow_OrderInSet", v)
		if k is "override_lyrics_path" then my setKMVar("LiveShow_OverrideLyricsPath", v)
		if k is "override_scroll_y" then my setKMVar("LiveShow_OverrideScrollY", v)
		if k is "override_cam_profile_id" then my setKMVar("LiveShow_OverrideCamProfileID", v)
		if k is "song_name" then my setKMVar("LiveShow_SongName", v)
		if k is "artist" then my setKMVar("LiveShow_Artist", v)
		if k is "default_lyrics_path" then my setKMVar("LiveShow_DefaultLyricsPath", v)
		if k is "default_scroll_y" then my setKMVar("LiveShow_DefaultScrollY", v)
		if k is "cam_profile_id" then my setKMVar("LiveShow_DefaultCamProfileID", v)
		if k is "set_name" then my setKMVar("LiveShow_RequiredSetName", v)
		if k is "set_file_name" then my setKMVar("LiveShow_RequiredSetFileName", v)
		if k is "effective_lyrics_path" then my setKMVar("LiveShow_EffectiveLyricsPath", v)
		if k is "effective_scroll_y" then my setKMVar("LiveShow_EffectiveScrollY", v)
		if k is "effective_cam_profile_id" then my setKMVar("LiveShow_EffectiveCamProfileID", v)
	end if
end repeat

if my getKMVar("LiveShow_SetSongID") is "" then
	my setKMVar("LiveShow_ResolveStatus", "ERROR")
	my setKMVar("LiveShow_ResolveMessage", "No matching set_song row")
	display dialog "No matching set_song row for set_list_id=" &amp; setListID &amp; " song_master_id=" &amp; songMasterID buttons {"OK"} default button 1
	return
end if

set requiredFile to my getKMVar("LiveShow_RequiredSetFileName")
set currentFile to my getKMVar("LiveShow_CurrentSetFileName")

if requiredFile is not "" and currentFile is not requiredFile then
	tell application "Keyboard Maestro Engine"
		do script "GarageBand_Load_Set_File" with parameter requiredFile
	end tell
	delay 5
end if

my setKMVar("LiveShow_ResolveStatus", "OK")
my setKMVar("LiveShow_ResolveMessage", "Resolved successfully")

set targetTime to my getKMVar("LiveShow_StartTime")
if targetTime is not "" then
	my setKMVar("LiveShow_TargetTime", targetTime)
	try
		tell application "Keyboard Maestro Engine"
			do script "GarageBand Go To Time"
		end tell
	end try
end if

set lyricsPath to my getKMVar("LiveShow_EffectiveLyricsPath")
if lyricsPath is not "" then
	try
		do shell script "open " &amp; quoted form of lyricsPath
	end try
end if

my setKMVar("LiveShow_CommandStatus", "OK")
my setKMVar("LiveShow_CommandMessage", "Song resolve/load complete")</string>
