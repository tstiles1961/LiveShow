						<string>#!/bin/zsh -f
rm -f /tmp/tim_live_show_stage_mode.stop /tmp/tim_live_show_stage_mode.lastsong
/usr/bin/osascript &lt;&lt;OSA
tell application "Keyboard Maestro Engine"
    try
        setvariable "LiveShow_Running" to "0"
        setvariable "LiveShow_CurrentSong" to ""
        setvariable "LiveShow_CurrentLyricsPath" to ""
        setvariable "LiveShow_LastError" to ""
        setvariable "GB_CurrentSeconds" to ""
    end try
end tell
OSA
echo "Live Show state reset."
</string>
