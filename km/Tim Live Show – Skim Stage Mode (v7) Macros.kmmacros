						<key>Text</key>
						<string>#!/bin/zsh -f
PATH=/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin
CURRENT_SECONDS="$(/usr/bin/osascript -e 'tell application "Keyboard Maestro Engine" to getvariable "GB_CurrentSeconds"')"
RAW="$(/usr/bin/osascript -e 'tell application "Keyboard Maestro Engine" to getvariable "GB_CurrentTimeRaw"')"
CSV_PATH="$(/usr/bin/osascript -e 'tell application "Keyboard Maestro Engine" to getvariable "LiveShow_CSVPath"')"
[[ -z "$CSV_PATH" ]] &amp;&amp; CSV_PATH="/Users/timstiles/Music/LiveShow/Set1.csv"
[[ -z "$CURRENT_SECONDS" ]] &amp;&amp; CURRENT_SECONDS="$RAW"

python3 - "$CURRENT_SECONDS" "$CSV_PATH" "$RAW" &lt;&lt;'PY'
import csv, io, re, sys, unicodedata
from pathlib import Path
cur_raw, csv_path, raw = sys.argv[1].strip(), sys.argv[2].strip(), sys.argv[3].strip()
SMART = str.maketrans({"\u2018":"'","\u2019":"'","\u201B":"'","\u201C":'"',"\u201D":'"',"\u00A0":' '})
def clean(s):
    return unicodedata.normalize("NFKC", s or "").translate(SMART).strip().strip("\ufeff").strip("\"'")
def parse_time(s):
    s=clean(s).replace(",", ".")
    if re.fullmatch(r"\d+(?:\.\d+)?", s): return float(s)
    if re.fullmatch(r"\d+:\d{2}\.\d{1,3}", s):
        m,sec=s.split(":"); return int(m)*60+float(sec)
    parts=s.split(":")
    if len(parts)==4:
        h,m,sec,frac=parts; return int(h)*3600+int(m)*60+int(sec)+float("0."+frac)
    if len(parts)==3:
        h,m,sec=parts; return int(h)*3600+int(m)*60+float(sec)
    if len(parts)==2:
        m,sec=parts; return int(m)*60+float(sec)
    return float(s)
text=Path(csv_path).read_text(encoding="utf-8-sig", errors="replace")
try:
    dialect=csv.Sniffer().sniff(text[:4096], delimiters=",\t;")
except Exception:
    dialect=csv.excel
reader=csv.DictReader(io.StringIO(text), dialect=dialect)
if reader.fieldnames:
    reader.fieldnames=[clean(h) for h in reader.fieldnames]
cur=parse_time(cur_raw)
rows=[]
for row in reader:
    row={clean(k):clean(v) for k,v in row.items() if k is not None}
    t=row.get("StartTime","")
    if not t: continue
    rows.append((parse_time(t), row.get("SongName",""), row.get("LyricsPath","")))
rows.sort()
song=""; path=""
for i,(start,name,pdf) in enumerate(rows):
    nxt=rows[i+1][0] if i+1&lt;len(rows) else 10**12
    if start &lt;= cur &lt; nxt:
        song=name; path=pdf; break
print(f"GB_CurrentTimeRaw=[[{raw}]]\nGB_CurrentSeconds=[[{cur_raw}]]\nCSV=[[{csv_path}]]\nSong=[[{song}]]\nPath=[[{path}]]")
PY
</string>
