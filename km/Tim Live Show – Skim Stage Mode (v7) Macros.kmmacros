						<key>Text</key>
						<string>#!/bin/zsh -f
/usr/bin/osascript &lt;&lt;'OSA'
set splitRatio to 0.28
set topRatio to 0.34

tell application "Finder"
    set b to bounds of window of desktop
end tell
set screenLeft to item 1 of b
set screenTop to item 2 of b
set screenRight to item 3 of b
set screenBottom to item 4 of b
set screenWidth to screenRight - screenLeft
set screenHeight to screenBottom - screenTop
set gbWidth to (screenWidth * splitRatio) as integer
set gbHeight to (screenHeight * topRatio) as integer
set skimLeft to screenLeft + gbWidth
set skimWidth to screenWidth - gbWidth

tell application "GarageBand" to activate
delay 0.3
tell application "Skim" to activate
delay 0.3

tell application "System Events"
    tell process "GarageBand"
        try
            set position of window 1 to {screenLeft, screenTop}
            set size of window 1 to {gbWidth, gbHeight}
        end try
    end tell
    tell process "Skim"
        try
            key code 53
        end try
        delay 0.2
        try
            set position of window 1 to {skimLeft, screenTop}
            set size of window 1 to {skimWidth, screenHeight}
        end try
    end tell
end tell
OSA

echo "Single-screen OCR layout applied: GarageBand visible on the left, Skim large on the right."
</string>
