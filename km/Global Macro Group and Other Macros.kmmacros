						<key>Text</key>
						<string>use AppleScript version "2.4"
use scripting additions

on setKMVar(varName, varValue)
	tell application "Keyboard Maestro Engine"
		setvariable varName to (varValue as text)
	end tell
end setKMVar

set bandFileName to "%TriggerValue%"
if bandFileName is "" then
	display dialog "GarageBand_Load_Set_File: missing TriggerValue" buttons {"OK"} default button 1
	return
end if

my setKMVar("LiveShow_RequiredSetFileName", bandFileName)
my setKMVar("LiveShow_IsSetLoading", "1")

set fullPath to "/Users/timstiles/Music/GarageBand/" &amp; bandFileName
my setKMVar("LiveShow_RequiredSetFullPath", fullPath)

tell application "System Events"
	if not (exists disk item fullPath) then
		my setKMVar("LiveShow_IsSetLoading", "0")
		display dialog "GarageBand file not found:" &amp; return &amp; fullPath buttons {"OK"} default button 1
		return
	end if
end tell

do shell script "open " &amp; quoted form of fullPath
tell application "GarageBand" to activate
delay 5

if bandFileName is "Set 1 Welcome.band" then
	my setKMVar("LiveShow_CurrentSetListID", "1")
	my setKMVar("LiveShow_CurrentSetName", "Set1")
else if bandFileName is "Set 2 Deep Cuts.band" then
	my setKMVar("LiveShow_CurrentSetListID", "2")
	my setKMVar("LiveShow_CurrentSetName", "Set2")
else if bandFileName is "Set 3 Soul &amp; Groove.band" then
	my setKMVar("LiveShow_CurrentSetListID", "3")
	my setKMVar("LiveShow_CurrentSetName", "Set3")
else if bandFileName is "Set 4 Send Off.band" then
	my setKMVar("LiveShow_CurrentSetListID", "4")
	my setKMVar("LiveShow_CurrentSetName", "Set4")
end if

my setKMVar("LiveShow_CurrentSetFileName", bandFileName)
my setKMVar("LiveShow_LastLoadedSetAt", do shell script "date '+%Y-%m-%d %H:%M:%S'")
my setKMVar("LiveShow_IsSetLoading", "0")
display notification "Loaded " &amp; bandFileName with title "Keyboard Maestro"</string>
						<key>TimeOutAbortsMacro</key>
						<true/>
						<key>TrimResults</key>
						<true/>
						<key>TrimResultsNew</key>
