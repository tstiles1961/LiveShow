						<string>use AppleScript version "2.4"
use framework "Foundation"
use scripting additions

on setKMVar(varName, varValue)
	tell application "Keyboard Maestro Engine"
		setvariable varName to (varValue as text)
	end tell
end setKMVar

on getKMVar(varName)
	tell application "Keyboard Maestro Engine"
		return getvariable varName
	end tell
end getKMVar

set rawJSON to "%TriggerValue%"
my setKMVar("LiveShow_CommandJSON", rawJSON)
my setKMVar("LiveShow_CommandStatus", "PARSING")
my setKMVar("LiveShow_LastCommandInput", rawJSON)

set py to "
import json, sys
raw = sys.argv[1]
result = {
 'action':'',
 'source':'',
 'set_list_id':'',
 'song_master_id':'',
 'set_song_id':'',
 'time':'',
 'song_name':'',
 'artist':'',
 'band_file_name':'',
 'band_file_path':'',
 'needs_set_load':'',
 'parse_ok':'0',
 'parse_error':''
}
try:
    cmd = json.loads(raw)
    result['action'] = str(cmd.get('action','')).strip()
    result['source'] = str(cmd.get('source','')).strip()
    result['set_list_id'] = str(cmd.get('set_list_id','')).strip()
    result['song_master_id'] = str(cmd.get('song_master_id','')).strip()
    result['set_song_id'] = str(cmd.get('set_song_id','')).strip()
    result['time'] = str(cmd.get('time','')).strip()
    result['song_name'] = str(cmd.get('songName', cmd.get('song_name',''))).strip()
    result['artist'] = str(cmd.get('artist','')).strip()
    result['band_file_name'] = str(cmd.get('band_file_name','')).strip()
    result['band_file_path'] = str(cmd.get('band_file_path','')).strip()
    result['needs_set_load'] = str(cmd.get('needs_set_load','')).strip()
    result['parse_ok'] = '1'
except Exception as e:
    result['parse_error'] = str(e)

for k, v in result.items():
    print(f'{k}={v}')
"
try
	set parsedLines to do shell script "/usr/bin/python3 -c " &amp; quoted form of py &amp; space &amp; quoted form of rawJSON
on error errMsg
	my setKMVar("LiveShow_CommandStatus", "ERROR")
	my setKMVar("LiveShow_CommandMessage", "JSON parse failed: " &amp; errMsg)
	display dialog "LiveShow_Command parse failed: " &amp; errMsg buttons {"OK"} default button 1
	return
end try

repeat with oneLine in paragraphs of parsedLines
	if oneLine contains "=" then
		set AppleScript's text item delimiters to "="
		set k to text item 1 of oneLine
		set v to (items 2 thru -1 of text items of oneLine) as text
		set AppleScript's text item delimiters to ""
		if k is "action" then my setKMVar("LiveShow_CommandAction", v)
		if k is "source" then my setKMVar("LiveShow_CommandSource", v)
		if k is "set_list_id" then my setKMVar("LiveShow_SetListID", v)
		if k is "song_master_id" then my setKMVar("LiveShow_SongMasterID", v)
		if k is "set_song_id" then my setKMVar("LiveShow_SetSongID", v)
		if k is "time" then my setKMVar("LiveShow_TargetTime", v)
		if k is "song_name" then my setKMVar("LiveShow_CommandSongName", v)
		if k is "artist" then my setKMVar("LiveShow_CommandArtist", v)
		if k is "band_file_name" then my setKMVar("LiveShow_CommandBandFileName", v)
		if k is "band_file_path" then my setKMVar("LiveShow_CommandBandFilePath", v)
		if k is "needs_set_load" then my setKMVar("LiveShow_CommandNeedsSetLoad", v)
		if k is "parse_ok" then my setKMVar("LiveShow_CommandParseOK", v)
		if k is "parse_error" then my setKMVar("LiveShow_CommandParseError", v)
	end if
end repeat

my setKMVar("LiveShow_LastCommandAt", do shell script "date '+%Y-%m-%d %H:%M:%S'")

set actionName to my getKMVar("LiveShow_CommandAction")
if actionName is "" then
	my setKMVar("LiveShow_CommandStatus", "ERROR")
	my setKMVar("LiveShow_CommandMessage", "Missing action")
	display dialog "LiveShow_Command: missing action" buttons {"OK"} default button 1
	return
end if

if actionName is "jumpToSong" then
	my setKMVar("LiveShow_CommandStatus", "ROUTING")
	tell application "Keyboard Maestro Engine"
		do script "LiveShow_Resolve_And_Load"
	end tell
else if actionName is "loadSetFile" then
	tell application "Keyboard Maestro Engine"
		do script "GarageBand_Load_Set_File" with parameter (my getKMVar("LiveShow_CommandBandFileName"))
	end tell
else
	my setKMVar("LiveShow_CommandStatus", "ERROR")
	my setKMVar("LiveShow_CommandMessage", "Unknown action: " &amp; actionName)
	display dialog "Unknown LiveShow action: " &amp; actionName buttons {"OK"} default button 1
end if</string>
