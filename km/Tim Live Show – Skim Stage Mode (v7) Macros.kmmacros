						<string>#!/bin/zsh -f
PATH=/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin
STOP_FILE="/tmp/tim_live_show_stage_mode.stop"
STATE_FILE="/tmp/tim_live_show_stage_mode.lastsong"
rm -f "$STOP_FILE"

km_get() {
/usr/bin/osascript -e 'tell application "Keyboard Maestro Engine" to getvariable "'$1'"'
}

km_set() {
/usr/bin/osascript -e 'tell application "Keyboard Maestro Engine" to setvariable "'$1'" to "'$2'"'
}

run_find_position() {
/usr/bin/osascript &lt;&lt;'OSA'
tell application "Keyboard Maestro Engine"
    do script "GarageBand Find Position"
end tell
OSA
}

prepare_skim() {
/usr/bin/osascript &lt;&lt;'OSA'
tell application "Skim"
    activate
    try
        tell front document to close saving no
    end try
end tell
OSA
}

run_stage_mode() {
/usr/bin/osascript &lt;&lt;'OSA'
tell application "Skim" to activate
delay 0.4
tell application "System Events"
    tell process "Skim"
        try
            click menu item "Enter Full Screen" of menu "View" of menu bar item "View" of menu bar 1
        end try
    end tell
    delay 0.5
    keystroke "a" using {command down, option down}
end tell
OSA
}

find_song_json() {
python3 - "$1" "$2" &lt;&lt;'ENDPY'
import csv, io, json, re, sys, unicodedata
from pathlib import Path

cur_raw = (sys.argv[1] or "").strip()
csv_path = (sys.argv[2] or "").strip() or "/Users/timstiles/Music/LiveShow/Set1.csv"

SMART = str.maketrans({
    "\u2018": "'", "\u2019": "'", "\u201B": "'",
    "\u201C": '"', "\u201D": '"',
    "\u00A0": ' ',
})

def clean_text(s: str) -&gt; str:
    s = unicodedata.normalize("NFKC", s or "")
    s = s.translate(SMART)
    return s.strip().strip("\ufeff").strip("\"'")

def parse_time(s: str) -&gt; float:
    s = clean_text(s)
    if not s:
        return -1.0
    if re.fullmatch(r"\d+(?:\.\d+)?", s):
        return float(s)
    s = s.replace(",", ".")
    if re.fullmatch(r"\d+:\d{2}\.\d{1,3}", s):
        m, sec = s.split(":")
        return int(m) * 60 + float(sec)
    parts = s.split(":")
    if len(parts) == 4:
        h, m, sec, frac = parts
        return int(h) * 3600 + int(m) * 60 + int(sec) + float("0." + frac)
    if len(parts) == 3:
        h, m, sec = parts
        return int(h) * 3600 + int(m) * 60 + float(sec)
    if len(parts) == 2:
        m, sec = parts
        return int(m) * 60 + float(sec)
    raise ValueError(f"Unrecognized time: {s}")

def normalize_path(p: str) -&gt; str:
    return clean_text(p).replace("\\ ", " ").replace("\\'", "'")

def resolve_path(path: str, song: str) -&gt; str:
    candidates = []
    if path:
        candidates.append(path)
        candidates.append(path.replace("\u2019", "'").replace("\u2018", "'"))
    fallback = f"/Users/timstiles/Music/LiveShow/Lyrics/{clean_text(song)}.pdf"
    candidates.append(fallback)
    candidates.append(fallback.replace("\u2019", "'").replace("\u2018", "'"))
    seen = set()
    for cand in candidates:
        cand = normalize_path(cand)
        if not cand or cand in seen:
            continue
        seen.add(cand)
        if Path(cand).exists():
            return cand
    return normalize_path(path or fallback)

p = Path(csv_path)
if not p.exists():
    print(json.dumps({"ok": False, "reason": f"CSV not found: {csv_path}"}))
    raise SystemExit

current = parse_time(cur_raw)
raw_text = p.read_text(encoding="utf-8-sig", errors="replace")
try:
    dialect = csv.Sniffer().sniff(raw_text[:4096], delimiters=",\t;")
except Exception:
    dialect = csv.excel
reader = csv.DictReader(io.StringIO(raw_text), dialect=dialect)
if reader.fieldnames:
    reader.fieldnames = [clean_text(h) for h in reader.fieldnames]

rows = []
for row in reader:
    row = {clean_text(k): clean_text(v) for k, v in row.items() if k is not None}
    start_raw = row.get("StartTime", "")
    song = row.get("SongName", "")
    path = row.get("LyricsPath", "")
    scroll = row.get("ScrollY", "")
    if not start_raw or not song:
        continue
    try:
        start = parse_time(start_raw)
    except Exception:
        continue
    rows.append({"start": start, "song": song, "path": resolve_path(path, song), "scroll": scroll})

rows.sort(key=lambda r: r["start"])
current_song = None
for i, row in enumerate(rows):
    next_start = rows[i + 1]["start"] if i + 1 &lt; len(rows) else float("inf")
    if row["start"] &lt;= current &lt; next_start:
        current_song = row
        break

if current_song is None:
    print(json.dumps({
        "ok": False,
        "reason": f"No matching song row for current_seconds={current:.3f}",
        "current_seconds": round(current, 3),
        "csv_path": csv_path,
        "row_count": len(rows),
    }))
else:
    print(json.dumps({
        "ok": True,
        "current_seconds": round(current, 3),
        "song": current_song["song"],
        "path": current_song["path"],
        "scroll": current_song.get("scroll", ""),
        "csv_path": csv_path,
    }))
ENDPY
}

while true; do
  [[ -e "$STOP_FILE" ]] &amp;&amp; break

  run_find_position &gt;/dev/null 2&gt;&amp;1
  sleep 0.25

  CURRENT_SECONDS="$(km_get "GB_CurrentSeconds" | tr -d '\r')"
  [[ -z "$CURRENT_SECONDS" ]] &amp;&amp; CURRENT_SECONDS="$(km_get "GB_CurrentTimeRaw" | tr -d '\r')"
  CSV_PATH="$(km_get "LiveShow_CSVPath" | tr -d '\r')"
  [[ -z "$CSV_PATH" ]] &amp;&amp; CSV_PATH="/Users/timstiles/Music/LiveShow/Set1.csv"

  RESULT="$(find_song_json "$CURRENT_SECONDS" "$CSV_PATH")"
  OK="$(printf '%s' "$RESULT" | python3 -c 'import sys,json; d=json.load(sys.stdin); print("1" if d.get("ok") else "0")')"
  if [[ "$OK" == "1" ]]; then
    CURRENT_SECONDS_OUT="$(printf '%s' "$RESULT" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("current_seconds",""))')"
    SONG="$(printf '%s' "$RESULT" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("song",""))')"
    PDF_PATH="$(printf '%s' "$RESULT" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("path",""))')"
    km_set "GB_CurrentSeconds" "$CURRENT_SECONDS_OUT"
    km_set "LiveShow_CurrentSong" "$SONG"
    km_set "LiveShow_CurrentLyricsPath" "$PDF_PATH"
    km_set "LiveShow_LastError" ""

    LAST_SONG=""
    [[ -f "$STATE_FILE" ]] &amp;&amp; LAST_SONG="$(cat "$STATE_FILE")"
    if [[ -n "$SONG" &amp;&amp; "$SONG" != "$LAST_SONG" ]]; then
      if [[ -f "$PDF_PATH" ]]; then
        prepare_skim &gt;/dev/null 2&gt;&amp;1
        sleep 0.2
        /usr/bin/open -a "Skim" "$PDF_PATH"
        echo -n "$SONG" &gt; "$STATE_FILE"
        sleep 1.0
        run_stage_mode &gt;/dev/null 2&gt;&amp;1
      else
        km_set "LiveShow_LastError" "PDF not found: $PDF_PATH"
      fi
    fi
  else
    ERR="$(printf '%s' "$RESULT" | python3 -c 'import sys,json; print(json.load(sys.stdin).get("reason","No match"))')"
    km_set "LiveShow_CurrentSong" ""
    km_set "LiveShow_CurrentLyricsPath" ""
    km_set "LiveShow_LastError" "$ERR"
  fi

  sleep 5
done

km_set "LiveShow_Running" "0"
exit 0
</string>
