						<string>#!/bin/zsh -f
touch /tmp/tim_live_show_stage_mode.stop
/usr/bin/osascript &lt;&lt;OSA
tell application "Keyboard Maestro Engine"
    try
        setvariable "LiveShow_Running" to "0"
    end try
end tell
OSA
echo "Stage Mode / GarageBand Find Position polling stop signal sent."
