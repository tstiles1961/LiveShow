						<key>Text</key>
						<string>input="$(cat)"
input="$(printf "%s" "$input" | tr -d '\r\n' | xargs)"
if [[ "$input" =~ ^([0-9]+):([0-9]+)\.([0-9]+)$ ]]; then
  min="${BASH_REMATCH[1]}"
  sec="${BASH_REMATCH[2]}"
  ms="${BASH_REMATCH[3]}"
  awk "BEGIN { printf \"%.3f\", ($min*60)+$sec+($ms/1000) }"
elif [[ "$input" =~ ^([0-9]+):([0-9]+)$ ]]; then
  min="${BASH_REMATCH[1]}"
  sec="${BASH_REMATCH[2]}"
  awk "BEGIN { printf \"%.3f\", ($min*60)+$sec }"
else
  exit 1
fi</string>
